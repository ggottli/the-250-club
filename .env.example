# Upstash Redis (REST API) — required.
#
# On Vercel: add the "Upstash for Redis" integration from the Marketplace
# (or run `vercel install upstash/upstash-kv`). It auto-injects credentials
# into your project's environment — you normally won't set them by hand.
#
# Note: depending on how the integration was installed, Vercel injects
# either UPSTASH_REDIS_REST_URL/TOKEN or the legacy KV_REST_API_URL/TOKEN
# names (a holdover from Vercel KV). lib/redis.ts accepts either pair, so
# just use whichever `vercel env pull` gives you.
#
# For local development: create a free database at https://console.upstash.com,
# open its REST API tab, and copy the values below into a `.env.local` file.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
